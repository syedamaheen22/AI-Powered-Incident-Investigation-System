{
  "name": "genai",
  "version": "1.0.0",
  "type": "module",
  "description": "Sample Project for Generative AI using LangChain and Zod",
  "main": "index.js",
  "scripts": {
    "test": "npx tsc --noEmit",
    "run:import-public-incidents": "npx tsx scripts/phase1/importPublicIncidentDataset.ts",
    "run:merge-incidents": "npx tsx scripts/phase1/mergeIncidentDatasets.ts",
    "run:generate-tickets": "npx tsx scripts/phase1/generateIncidentTickets.ts",
    "run:generate-runbooks": "npx tsx scripts/phase1/generateRunbooks.ts",
    "run:generate-deployments": "npx tsx scripts/phase1/generateDeploymentHistory.ts",
    "run:generate-graph": "npx tsx scripts/phase1/generateKnowledgeGraph.ts",
    "run:hybrid-rag": "npx tsx scripts/phase2/hybridRAG.ts",
    "run:knowledge-graph": "npx tsx scripts/phase2/knowledgeGraph.ts",
    "run:multi-agent": "npx tsx scripts/phase2/multiAgent.ts",
    "run:phase3-advanced": "npx tsx scripts/phase3/advancedFeatures.ts",
    "run:evaluate-phase3": "npx tsx scripts/phase3/evaluateSystem.ts",
    "run:day1-decoding": "npx ts-node tasks/day1/decodingSettings.ts",
    "run:day1-tokenizer": "npx ts-node tasks/day1/tokenizationCompare.ts",
    "run:day2-long-context": "npx ts-node tasks/day2/longContextStrategies.ts",
    "run:day2-prompt-pack": "npx ts-node tasks/day2/promptPackEvaluate.ts",
    "run:prompt-pack": "npx ts-node tasks/day2/promptPackEvaluate.ts",
    "run:day3-pdf-eval": "npx ts-node tasks/day3/pdfEvaluate.ts",
    "run:day3-extract-facts": "node tasks/day3/_extractFactsForTestSet.cjs",
    "run:pdf-eval": "npx ts-node tasks/day3/pdfEvaluate.ts",
    "run:day4-rag-pdf-eval": "npx ts-node tasks/day4-5/ragPdfEvaluate.ts",
    "run:day5-rag-pdf-eval": "npx ts-node tasks/day4-5/ragPdfEvaluate.ts",
    "run:rag-pdf-eval": "npx ts-node tasks/day4-5/ragPdfEvaluate.ts",
    "run:day6-chunking": "npx ts-node tasks/day6/chunkingStrategyCompare.ts",
    "run:day7-query-opt": "npx ts-node tasks/day7/queryOptimizationCompare.ts",
    "run:day8-retrieval-rerank": "npx ts-node tasks/day8/retrievalRerankCompare.ts",
    "run:day9-answer-gen": "npx ts-node tasks/day9/answerGenCompare.ts",
    "run:day11-tool-calling": "npx tsx tasks/day11/toolCallingEvaluation.ts",
    "run:day12-agent-pattern": "npx tsx tasks/day12/agentPatternComparison.ts",
    "run:day13-kg": "npx tsx tasks/day13/kgHandsOnComparison.ts",
    "run:week2-travel-rag": "npx tsx tasks/week2assignment/travelRagServer.ts",
    "run:week3-server": "cd tasks/week3assignment && ../../.venv/bin/uvicorn server:app --reload --port 8000",
    "run:week3-ui": "cd tasks/week3assignment && ../../.venv/bin/streamlit run streamlit_app.py --server.port 8501",
    "run:iot-news-server": "cd tasks/iot-news-brief-agent && ../../.venv/bin/uvicorn server:app --reload --port 8010",
    "run:iot-news-ui": "cd tasks/iot-news-brief-agent && ../../.venv/bin/streamlit run streamlit_app.py --server.port 8510",
    "run:iot-news-ts": "npx tsx tasks/iot-news-brief-agent-ts/server.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@dqbd/tiktoken": "^1.0.22",
    "@langchain/community": "^1.1.8",
    "@langchain/core": "^1.1.17",
    "@langchain/ollama": "^1.2.1",
    "chromadb": "^3.3.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "gpt-3-encoder": "^1.1.4",
    "hnswlib-node": "^3.0.0",
    "langchain": "^1.2.14",
    "openai": "^4.104.0",
    "pdf-parse": "^1.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^25.0.10",
    "rss-parser": "^3.13.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
